<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:orientation="vertical">

    <!-- Fixed Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="20dp"
        android:paddingBottom="12dp">

        <!-- Title row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📜 Recent Activity"
                android:textColor="#FFD54F"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/liveBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  LIVE  "
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="#CC2E7D32"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Last 10 sensor events"
            android:textColor="#90A4AE"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- Mini stat strip -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="horizontal"
            android:padding="14dp"
            android:elevation="6dp"
            android:weightSum="3">

            <!-- DANGER column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔴"
                    android:textSize="20sp"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/miniDanger"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#EF5350"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Danger"
                    android:textColor="#78909C"
                    android:textSize="11sp"
                    android:gravity="center" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#2D4A6A"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp" />

            <!-- WARNING column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🟡"
                    android:textSize="20sp"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/miniWarning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFB300"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Warning"
                    android:textColor="#78909C"
                    android:textSize="11sp"
                    android:gravity="center" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#2D4A6A"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp" />

            <!-- SAFE column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🟢"
                    android:textSize="20sp"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/miniSafe"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#66BB6A"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Safe"
                    android:textColor="#78909C"
                    android:textSize="11sp"
                    android:gravity="center" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

    <!-- Timeline label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TIMELINE  ↓  NEWEST FIRST"
        android:textColor="#546E7A"
        android:textSize="10sp"
        android:letterSpacing="0.15"
        android:paddingStart="18dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp" />

    <!-- Scrollable event cards -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="24dp"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/eventsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </ScrollView>

</LinearLayout>