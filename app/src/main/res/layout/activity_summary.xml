<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📊 Summary"
            android:textColor="#FFD54F"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Your session at a glance"
            android:textColor="#90A4AE"
            android:textSize="14sp"
            android:layout_marginBottom="20dp" />

        <!-- Safety Score Card -->
        <LinearLayout
            android:id="@+id/scoreCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:elevation="8dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SAFETY SCORE"
                android:textColor="#90A4AE"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/safetyScoreText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#FFD54F"
                android:textSize="52sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/safetyLabelText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No data yet"
                android:textColor="#B0BEC5"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- Obstacle Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp"
            android:weightSum="3">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="16dp"
                android:elevation="6dp"
                android:layout_marginEnd="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🔴" android:textSize="28sp" />
                <TextView android:id="@+id/dangerCount"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textColor="#EF5350" android:textSize="24sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Danger" android:textColor="#90A4AE" android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="16dp"
                android:elevation="6dp"
                android:layout_marginEnd="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🟡" android:textSize="28sp" />
                <TextView android:id="@+id/warningCount"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textColor="#FFB300" android:textSize="24sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Warning" android:textColor="#90A4AE" android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="16dp"
                android:elevation="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🟢" android:textSize="28sp" />
                <TextView android:id="@+id/safeCount"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textColor="#66BB6A" android:textSize="24sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Safe" android:textColor="#90A4AE" android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Environment Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:elevation="8dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ENVIRONMENT"
                android:textColor="#90A4AE"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="14dp" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🌑  Dark readings" android:textColor="#CFD8DC" android:textSize="15sp"
                    android:layout_weight="1" />
                <TextView android:id="@+id/darkCount"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textColor="#FFD54F" android:textSize="15sp" android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="⚠️  Dark + obstacle" android:textColor="#CFD8DC" android:textSize="15sp"
                    android:layout_weight="1" />
                <TextView android:id="@+id/riskCount"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textColor="#EF5350" android:textSize="15sp" android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Activity Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:elevation="8dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACTIVITY BREAKDOWN"
                android:textColor="#90A4AE"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="14dp" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🏃  Running" android:textColor="#CFD8DC" android:textSize="15sp"
                    android:layout_weight="1" />
                <TextView android:id="@+id/runCount"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0 events" android:textColor="#FFD54F" android:textSize="15sp" android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🚶  Walking" android:textColor="#CFD8DC" android:textSize="15sp"
                    android:layout_weight="1" />
                <TextView android:id="@+id/walkCount"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0 events" android:textColor="#FFD54F" android:textSize="15sp" android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Riskiest Hour Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:elevation="8dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🕐  RISKIEST HOUR"
                android:textColor="#90A4AE"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/worstHourText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#ECEFF1"
                android:textSize="17sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>