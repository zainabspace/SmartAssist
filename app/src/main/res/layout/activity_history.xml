<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:orientation="vertical">

    <!-- Fixed Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp"
        android:paddingBottom="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📁 History"
            android:textColor="#FFD54F"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All recorded sensor events"
            android:textColor="#90A4AE"
            android:textSize="14sp"
            android:layout_marginBottom="14dp" />

        <Button
            android:id="@+id/deleteButton"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:text="🗑️  Delete All History"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:backgroundTint="#C62828"
            android:layout_marginBottom="4dp" />
    </LinearLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="24dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- DANGER section -->
            <TextView
                android:id="@+id/dangerHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔴  DANGER EVENTS"
                android:textColor="#EF5350"
                android:textSize="12sp"
                android:letterSpacing="0.12"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/dangerContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="10dp" />

            <!-- WARNING section -->
            <TextView
                android:id="@+id/warningHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🟡  WARNING EVENTS"
                android:textColor="#FFB300"
                android:textSize="12sp"
                android:letterSpacing="0.12"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/warningContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="10dp" />

            <!-- SAFE section -->
            <TextView
                android:id="@+id/safeHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🟢  SAFE READINGS"
                android:textColor="#66BB6A"
                android:textSize="12sp"
                android:letterSpacing="0.12"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/safeContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="10dp" />

            <!-- Empty state -->
            <TextView
                android:id="@+id/emptyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No history yet.\nStart monitoring to begin recording."
                android:textColor="#546E7A"
                android:textSize="16sp"
                android:gravity="center"
                android:layout_marginTop="60dp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>